# See https://docs.github.com/en/get-started/git-basics/ignoring-files

# --- Dependencies ---
node_modules/

# --- Angular CLI ---
.angular/
*.tsbuildinfo

# --- Build / output ---
dist/
www/
out-tsc/
tmp/

# --- Ionic / Cordova ---
.ionic/
.sass-cache/
.sourcemaps/
.versions/
platforms/
plugins/

# --- Capacitor (native projects, if generated locally) ---
android/
ios/
.capacitor/

# --- Tests & coverage ---
coverage/
.nyc_output/
libpeerconnection.log
testem.log
/typings

# --- Logs ---
*.log
log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- IDE / OS ---
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/
*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*

# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- Firebase / local tooling ---
.firebase/
*-debug.log
.runtimeconfig.json

# --- Misc ---
*.orig
*.local
